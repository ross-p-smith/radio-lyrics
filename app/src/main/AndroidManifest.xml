<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />

    <!--
      Android 11+ (API 30) hides other apps from package queries by default. Without these entries
      MediaBrowserCompat.connect() to com.zoulou.dab returns ServiceNotFound even though the
      service is exported. Declared unconditionally because the cost is zero in non-DAB-Z builds.
    -->
    <queries>
        <package android:name="com.zoulou.dab" />
        <intent>
            <action android:name="android.media.browse.MediaBrowserService" />
        </intent>
    </queries>

    <application
        android:name=".RadioLyricApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:installLocation="internalOnly"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RadioLyric"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.RadioLyric"
            tools:ignore="DiscouragedApi,LockedOrientationActivity">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Auto-launch when the Mekede USB DAB dongle is plugged in. -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/mekede_dab_filter" />
        </activity>

        <!-- TODO(Phase 5): implement PlaybackService extending MediaSessionService. -->
        <service
            android:name=".playback.PlaybackService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <receiver
            android:name="androidx.media3.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Phase 9: autostart. AOSP boot/replace events plus the OEM ACC-on
             broadcasts this firmware actually emits (verified live on Mekede
             DUDU7, see docs/target-device-facts.md §9). The 11 unverified
             ACC_ON actions remain registered by default so other Mekede / FYT /
             Microntek firmwares stay covered, but they are gated behind the
             `includeFolkloreAccActions` Gradle property so we can A/B-trim
             them by passing `-Pradio.includeFolkloreAccActions=false`. -->
        <receiver
            android:name=".autostart.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <!-- AOSP boot signals -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <!-- MediaTek / quick-boot variants -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.BOOT_IPO" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <!-- Verified live on Mekede DUDU7 (2026-05-05 capture). -->
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="com.nwd.action.ACTION_MCU_STATE_CHANGE" />
                <!-- Confirmed OEM ACC-on broadcasts (gated, see manifestPlaceholders) -->
                <action android:name="${accAction1}" />
                <action android:name="${accAction2}" />
                <action android:name="${accAction3}" />
                <action android:name="${accAction4}" />
                <action android:name="${accAction5}" />
                <!-- Defensive folklore (seen in firmware logs / forum posts) -->
                <action android:name="${accAction6}" />
                <action android:name="${accAction7}" />
                <action android:name="${accAction8}" />
                <action android:name="${accAction9}" />
                <action android:name="${accAction10}" />
                <action android:name="${accAction11}" />
            </intent-filter>
        </receiver>

        <!--
          Dormant NotificationListenerService — registered so the user can flip it on in
          Settings → Apps → Notification access if the MediaBrowser happy path ever fails on a
          firmware that allow-lists `onLoadChildren` callers. The service is never auto-bound;
          consults are made only by `DabzBridgeRadioSource` after MediaBrowser connect failure.
        -->
        <service
            android:name=".bridge.DabzMediaListener"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>
</manifest>
